---
import PageLayout from "../../layouts/PageLayout.astro";
export const prerender = true;
---

<PageLayout title="Contact & Feedback" currentPage="about">
  <section aria-labelledby="contact-title" class="mb-10">
    <h1 id="contact-title" class="text-4xl font-bold mb-4">Contact &amp; Feedback</h1>
    <p class="text-lg text-gray-700 max-w-3xl leading-relaxed">
      Use this page to contribute incidents that fit the archive's scope and to send questions,
      corrections, bug reports, accessibility concerns, or general feedback.
    </p>
  </section>

  <section aria-labelledby="contribute-title" class="mb-10 rounded-xl border border-amber-200 bg-amber-50 p-6 shadow-sm">
    <h2 id="contribute-title" class="text-2xl font-semibold text-gray-900 mb-3">Contribute to the Dataset</h2>
    <p class="text-gray-700 leading-relaxed mb-4">
      The archive documents lethal anti-Chinese violence within the site's historical scope. If you
      have evidence of a lynching, massacre, riot, or other fatal anti-Chinese attack connected to
      the archive's time period and geography, you can submit it for review.
    </p>
    <a
      href="/submit"
      class="inline-flex items-center justify-center rounded-lg bg-amber-500 px-5 py-3 font-semibold text-amber-950 shadow-sm transition-colors hover:bg-amber-600 focus:outline-none focus:ring-2 focus:ring-amber-700 focus:ring-offset-2"
    >
      Submit an Incident
    </a>
    <p class="mt-4 text-sm text-gray-700">
      Submissions are reviewed before anything is added to the site. They are not published automatically.
    </p>
    <div class="mt-4 rounded-lg border border-amber-200 bg-white p-4">
      <h3 class="text-base font-semibold text-gray-900 mb-2">Helpful evidence to include</h3>
      <ul class="list-disc pl-5 space-y-1 text-sm text-gray-700">
        <li>Date or approximate date of the incident</li>
        <li>Place name, county, state, or territorial location</li>
        <li>Source citation or link to supporting evidence</li>
      </ul>
    </div>
  </section>

  <section id="feedback-questions" aria-labelledby="feedback-title" class="scroll-mt-24 rounded-xl border border-gray-200 bg-white p-6 shadow-sm">
    <h2 id="feedback-title" class="text-2xl font-semibold text-gray-900 mb-3">Feedback &amp; Questions</h2>
    <p class="text-gray-700 leading-relaxed mb-2">
      Use this form to ask a question, suggest a correction, report a bug, flag an accessibility issue,
      or share general feedback about the archive.
    </p>
    <p class="text-sm text-gray-700 mb-1">Required fields are marked <span aria-hidden="true">*</span>.</p>
    <div class="mb-6"></div>

    <div
      id="feedback-error-summary"
      class="mb-6 hidden rounded-lg border border-red-300 bg-red-50 px-4 py-3 text-sm text-red-900"
      role="alert"
      aria-live="assertive"
      tabindex="-1"
    >
      Please correct the errors below and resubmit the form.
    </div>

    <div
      id="feedback-submit-error"
      class="mb-6 hidden rounded-lg border border-red-300 bg-red-50 px-4 py-3 text-sm text-red-900"
      role="alert"
      aria-live="assertive"
      tabindex="-1"
    >
      Your feedback could not be submitted right now. Please try again.
    </div>

    <form
      id="feedback-form"
      name="contact-feedback"
      method="POST"
      action="/about/contact/success/"
      data-netlify="true"
      netlify-honeypot="bot-field"
      class="space-y-5"
      novalidate
    >
      <input type="hidden" name="form-name" value="contact-feedback" />
      <p class="hidden">
        <label for="bot-field">Do not fill out this field</label>
        <input id="bot-field" name="bot-field" autocomplete="off" tabindex="-1" />
      </p>

      <div>
        <label for="feedback-category" class="mb-1 block font-medium text-gray-900">
          Category <span aria-hidden="true" class="text-red-700">*</span>
        </label>
        <select
          id="feedback-category"
          name="category"
          required
          aria-describedby="feedback-category-error"
          class="w-full rounded-lg border border-gray-300 bg-white px-3 py-2 text-gray-900 shadow-sm focus:border-amber-500 focus:outline-none focus:ring-2 focus:ring-amber-500"
        >
          <option value="">Select a category</option>
          <option value="Question">Question</option>
          <option value="Correction">Correction</option>
          <option value="Bug">Bug</option>
          <option value="Accessibility">Accessibility</option>
          <option value="General feedback">General feedback</option>
        </select>
        <p id="feedback-category-error" class="mt-1 text-sm text-red-700"></p>
      </div>

      <div>
        <label for="feedback-message" class="mb-1 block font-medium text-gray-900">
          Message <span aria-hidden="true" class="text-red-700">*</span>
        </label>
        <textarea
          id="feedback-message"
          name="message"
          required
          rows="7"
          aria-describedby="feedback-message-hint feedback-message-error"
          class="w-full rounded-lg border border-gray-300 bg-white px-3 py-2 text-gray-900 shadow-sm focus:border-amber-500 focus:outline-none focus:ring-2 focus:ring-amber-500"
        ></textarea>
        <p id="feedback-message-hint" class="mt-1 text-sm text-gray-600">
          Include as much detail as you can, especially for corrections, bugs, or accessibility issues.
        </p>
        <p id="feedback-message-error" class="mt-1 text-sm text-red-700"></p>
      </div>

      <div>
        <label for="feedback-email" class="mb-1 block font-medium text-gray-900">Email (optional)</label>
        <input
          id="feedback-email"
          name="email"
          type="email"
          inputmode="email"
          autocomplete="email"
          aria-describedby="feedback-email-hint feedback-email-error"
          class="w-full rounded-lg border border-gray-300 bg-white px-3 py-2 text-gray-900 shadow-sm focus:border-amber-500 focus:outline-none focus:ring-2 focus:ring-amber-500"
        />
        <p id="feedback-email-hint" class="mt-1 text-sm text-gray-600">
          Share your email only if you would like a reply. Expect to wait a few days for a reply.
        </p>
        <p id="feedback-email-error" class="mt-1 text-sm text-red-700"></p>
      </div>

      <div class="pt-1">
        <button
          type="submit"
          id="feedback-submit-button"
          class="inline-flex items-center justify-center rounded-lg bg-gray-900 px-5 py-3 font-semibold text-white shadow-sm transition-colors hover:bg-gray-800 focus:outline-none focus:ring-2 focus:ring-amber-700 focus:ring-offset-2"
        >
          Send Feedback
        </button>
      </div>
    </form>

    <p class="mt-6 text-sm text-gray-700">
      Prefer email? You can also write to <a href="mailto:kevinhegg@gmail.com" class="text-accent underline hover:text-accent-focus">kevinhegg@gmail.com</a>.
    </p>
  </section>

  <iframe
    name="feedback-submit-target"
    id="feedback-submit-target"
    title="Feedback submission target"
    class="hidden"
  ></iframe>

  <div
    id="feedback-success-modal"
    class="fixed inset-0 z-[10000] hidden items-center justify-center bg-black/60 px-4"
    role="dialog"
    aria-modal="true"
    aria-labelledby="feedback-success-title"
    aria-describedby="feedback-success-message"
  >
    <div class="w-full max-w-md overflow-hidden rounded-xl border border-amber-200 bg-white shadow-2xl">
      <div class="border-b border-amber-200 bg-amber-50 px-6 py-4">
        <h2 id="feedback-success-title" class="text-xl font-semibold text-gray-900">Feedback Sent</h2>
      </div>
      <div class="p-6">
        <p id="feedback-success-message" class="text-gray-700 leading-relaxed text-center mb-6">
          Your feedback was submitted successfully.<br />
          Thank you!
        </p>
        <div class="flex justify-center">
          <button
            id="feedback-success-close"
            type="button"
            class="inline-flex items-center justify-center rounded-lg bg-gray-900 px-5 py-3 font-semibold text-white shadow-sm transition-colors hover:bg-gray-800 focus:outline-none focus:ring-2 focus:ring-amber-700 focus:ring-offset-2"
          >
            Close
          </button>
        </div>
      </div>
    </div>
  </div>
</PageLayout>

<script>
  // @ts-nocheck - client-side validation for static Netlify form
  const form = document.getElementById('feedback-form');
  const errorSummary = document.getElementById('feedback-error-summary');
  const submitError = document.getElementById('feedback-submit-error');
  const submitButton = document.getElementById('feedback-submit-button');
  const submitTarget = document.getElementById('feedback-submit-target');
  const successModal = document.getElementById('feedback-success-modal');
  const successClose = document.getElementById('feedback-success-close');
  const successPath = '/about/contact/success/';
  let lastFocusedElement = null;
  let pendingSubmission = false;

  const openSuccessModal = () => {
    if (!successModal) return;
    lastFocusedElement = document.activeElement instanceof HTMLElement ? document.activeElement : null;
    successModal.classList.remove('hidden');
    successModal.classList.add('flex');
    document.body.classList.add('overflow-hidden');
    if (successClose instanceof HTMLButtonElement) {
      successClose.focus();
    }
  };

  const closeSuccessModal = () => {
    if (!successModal) return;
    successModal.classList.add('hidden');
    successModal.classList.remove('flex');
    document.body.classList.remove('overflow-hidden');
    if (lastFocusedElement instanceof HTMLElement) {
      lastFocusedElement.focus();
    }
  };

  if (successClose instanceof HTMLButtonElement) {
    successClose.addEventListener('click', closeSuccessModal);
  }

  document.addEventListener('keydown', (event) => {
    if (event.key === 'Escape' && successModal && !successModal.classList.contains('hidden')) {
      closeSuccessModal();
    }
  });

  if (form instanceof HTMLFormElement) {
    form.setAttribute('target', 'feedback-submit-target');
    const fieldErrors = {
      category: 'Choose a category.',
      message: 'Enter your message.',
      email: 'Enter a valid email address or leave the field blank.',
    };

    const getErrorElement = (field) => document.getElementById(`${field.id}-error`);

    const validateField = (field) => {
      const errorElement = getErrorElement(field);
      if (!errorElement) return true;

      let message = '';
      if (field.validity.valueMissing) {
        message = fieldErrors[field.name] || 'This field is required.';
      } else if (field.validity.typeMismatch) {
        message = fieldErrors[field.name] || 'Enter a valid value.';
      }

      field.setAttribute('aria-invalid', message ? 'true' : 'false');
      errorElement.textContent = message;
      return !message;
    };

    const fields = Array.from(form.querySelectorAll('select, textarea, input[type="email"]'));
    fields.forEach((field) => {
      field.addEventListener('blur', () => validateField(field));
      field.addEventListener('input', () => {
        if (field.getAttribute('aria-invalid') === 'true') {
          validateField(field);
        }
      });
      field.addEventListener('change', () => {
        if (field.getAttribute('aria-invalid') === 'true') {
          validateField(field);
        }
      });
    });

    form.addEventListener('submit', (event) => {
      let hasErrors = false;
      let firstInvalidField = null;

      fields.forEach((field) => {
        const isValid = validateField(field);
        if (!isValid && !firstInvalidField) firstInvalidField = field;
        hasErrors = hasErrors || !isValid;
      });

      if (hasErrors) {
        event.preventDefault();
        if (errorSummary) {
          errorSummary.classList.remove('hidden');
          errorSummary.focus();
        }
        submitError?.classList.add('hidden');
        firstInvalidField?.focus();
        return;
      }

      if (errorSummary) {
        errorSummary.classList.add('hidden');
      }
      submitError?.classList.add('hidden');
      closeSuccessModal();
      pendingSubmission = true;

      if (submitButton instanceof HTMLButtonElement) {
        submitButton.disabled = true;
        submitButton.textContent = 'Sending...';
      }
    });
  }

  if (submitTarget instanceof HTMLIFrameElement) {
    submitTarget.addEventListener('load', () => {
      if (!pendingSubmission) return;
      pendingSubmission = false;

      let reachedSuccessPage = false;
      try {
        const iframePath = submitTarget.contentWindow?.location?.pathname || '';
        reachedSuccessPage = iframePath === successPath;
      } catch {
        reachedSuccessPage = false;
      }

      if (submitButton instanceof HTMLButtonElement) {
        submitButton.disabled = false;
        submitButton.textContent = 'Send Feedback';
      }

      if (!reachedSuccessPage) {
        submitError?.classList.remove('hidden');
        submitError?.focus?.();
        return;
      }

      if (form instanceof HTMLFormElement) {
        form.reset();
        const fields = Array.from(form.querySelectorAll('select, textarea, input[type="email"]'));
        fields.forEach((field) => {
          field.setAttribute('aria-invalid', 'false');
          const errorElement = document.getElementById(`${field.id}-error`);
          if (errorElement) errorElement.textContent = '';
        });
      }

      openSuccessModal();
    });
  }
</script>
