---
import PageLayout from "../../layouts/PageLayout.astro";
---

<PageLayout title="Contact" currentPage="about">
  <section aria-labelledby="contact-title" class="mb-8">
    <h1 id="contact-title" class="text-4xl font-bold mb-6">Contact</h1>

    <div class="prose prose-lg max-w-none text-gray-700">
      <p class="font-semibold text-base-content">Contact options are expanding.</p>
      <p>Questions about the archive, sources, datasets, or thesis?</p>
      <p>Please reach out:<br />kevinhegg@gmail.com</p>
      <p>A feedback form will be added soon.</p>
    </div>
  </section>
</PageLayout>
