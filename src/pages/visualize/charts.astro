---
import PageLayout from "../../layouts/PageLayout.astro";
import "../../styles/western-colors.css";

const mapboxToken =
  import.meta.env.PUBLIC_MAPBOX_ACCESS_TOKEN ||
  import.meta.env.PUBLIC_MAPBOX_TOKEN ||
  import.meta.env.MAPBOX_ACCESS_TOKEN ||
  "";
const mapboxStyle = "kevinhegg/cmd4pgf7p01ud01s4awo3b3yd";

// Hong Di lynching reports by state (N=1,406) - from Hong Di articles by State.xlsx
const HONG_DI_BY_STATE: Record<string, number> = {
  "California": 754, "Kansas": 122, "Nevada": 84, "Missouri": 40, "Arizona": 36,
  "Oregon": 35, "Pennsylvania": 35, "New York": 27, "Illinois": 26, "Ohio": 21,
  "Michigan": 20, "Indiana": 19, "Nebraska": 15, "Utah": 15, "Wisconsin": 13,
  "Massachusetts": 11, "Tennessee": 11, "Georgia": 10, "Washington": 10,
  "Minnesota": 9, "Kentucky": 7, "New Jersey": 7, "Texas": 7, "Alabama": 6,
  "Idaho": 6, "Vermont": 6, "District of Columbia": 5, "Montana": 5, "Virginia": 5,
  "Delaware": 4, "Louisiana": 4, "Maine": 4, "North Dakota": 4, "Connecticut": 3,
  "Florida": 3, "Hawaii": 3, "Iowa": 3, "Maryland": 3, "Mississippi": 2,
  "Arkansas": 1, "Colorado": 1, "New Mexico": 1, "South Carolina": 1,
  "West Virginia": 1, "Wyoming": 1
};

// Chinese Must Go mentions by state (N=2,875) - from chinese-must-go-distribution-loc-1878-1925-n-is-2875-clean.xlsx
const CHINESE_MUST_GO_BY_STATE: Record<string, number> = {
  "California": 269, "Montana": 141, "Nevada": 119, "Minnesota": 116, "Oregon": 114,
  "New York": 109, "Maine": 109, "Arizona": 102, "Illinois": 91, "Nebraska": 78,
  "District of Columbia": 74, "West Virginia": 72, "Connecticut": 69, "Kansas": 67,
  "Ohio": 67, "Texas": 67, "Wisconsin": 66, "Washington": 64, "Georgia": 59,
  "Hawaii": 59, "Virginia": 58, "Idaho": 55, "Pennsylvania": 54, "South Dakota": 54,
  "Wyoming": 49, "Utah": 48, "Tennessee": 44, "Louisiana": 44, "Missouri": 39,
  "Indiana": 36, "South Carolina": 35, "Colorado": 34, "Delaware": 34, "Michigan": 34,
  "Vermont": 34, "Mississippi": 33, "North Dakota": 33, "Kentucky": 32, "Alabama": 26,
  "Maryland": 25, "Iowa": 23, "New Jersey": 22, "New Mexico": 21, "Rhode Island": 19,
  "Arkansas": 18, "Florida": 15, "Massachusetts": 15, "North Carolina": 13,
  "New Hampshire": 12, "Oklahoma": 3, "Alaska": 1
};
---

<PageLayout title="Patterns of anti-Chinese Violence (1853-1915)" currentPage="visualize/charts">
  <div id="charts-top" class="container-wide scroll-mt-24">
    <!-- Breadcrumb Navigation -->
    <nav aria-label="Breadcrumb" class="mb-4">
      <ol class="flex items-center text-sm flex-wrap">
        <li class="flex items-center">
          <a href="/" class="text-gray-700 hover:text-accent hover:underline transition-colors">Home</a>
          <svg class="w-4 h-4 mx-2 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
          </svg>
        </li>
        <li class="flex items-center">
          <a href="/visualize" class="text-gray-700 hover:text-accent hover:underline transition-colors">Visualize the Data</a>
          <svg class="w-4 h-4 mx-2 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
          </svg>
        </li>
        <li class="text-gray-500 font-normal truncate max-w-xs" aria-current="page">
          Charts
        </li>
      </ol>
    </nav>
    <h1 class="text-4xl font-bold mb-6 text-vintage-ink">Patterns of anti-Chinese Violence (1853-1915)</h1>
    <div id="charts-overview" class="scroll-mt-24">
      <p class="mb-2 text-lg max-w-3xl leading-snug">
        These interactive charts and maps help visualize the history and impact of anti-Chinese violence in the second half of the 19th century.
      </p>
      <ol class="mb-8 text-base max-w-3xl leading-normal list-decimal list-inside space-y-1 pl-4" style="text-indent:-1.1em;">
      <li><a href="#chart-01" class="text-vintage-ink underline hover:no-underline focus:no-underline"><strong>Incidents Over Time:</strong></a> Annual count of violent events from 1850–1920.</li>
      <li><a href="#chart-02" class="text-vintage-ink underline hover:no-underline focus:no-underline"><strong>Victims Over Time:</strong></a> Annual victim count from 1850–1920.</li>
      <li><a href="#chart-03" class="text-vintage-ink underline hover:no-underline focus:no-underline"><strong>Incidents &amp; Victims Over Time:</strong></a> Stacked area chart combining incidents (N=75) and victims (N=191) from 1850–1920. Average number of victims per incident: 2.5.</li>
      <li><a href="#chart-04" class="text-vintage-ink underline hover:no-underline focus:no-underline"><strong>Incidents &amp; Victims by State:</strong></a> Stacked bars by decade; incident and victim counts per state (horizontal bars, sorted by victim count).</li>
      <li><a href="#chart-07" class="text-vintage-ink underline hover:no-underline focus:no-underline"><strong>Types of Violence:</strong></a> Breakdown of violence types by victim count.</li>
      <li><a href="#chart-08" class="text-vintage-ink underline hover:no-underline focus:no-underline"><strong>Categories &amp; Pretexts:</strong></a> Distribution of violence categories and stated pretexts.</li>
      <li><a href="#chart-10" class="text-vintage-ink underline hover:no-underline focus:no-underline"><strong>Killing Method:</strong></a> Distribution of how victims were killed.</li>
      <li><a href="#chart-11" class="text-vintage-ink underline hover:no-underline focus:no-underline"><strong>Violence &amp; Population:</strong></a> Victims per year alongside Chinese population growth and key policy events.</li>
      <li><a href="#chart-12" class="text-vintage-ink underline hover:no-underline focus:no-underline"><strong>Hong Di Lynching Reports by State:</strong></a> Geographic distribution of newspaper articles reporting the Hong Di lynching (Colusa, California, July 1887), by state of publication (N=1,406).</li>
      <li><a href="#chart-13" class="text-vintage-ink underline hover:no-underline focus:no-underline"><strong>"Chinese Must Go" Mentions by State:</strong></a> Geographic distribution of newspaper mentions of the anti-Chinese slogan "Chinese must go" by state of publication, 1878–1925 (N=2,875).</li>
      </ol>
    </div>
    <style>
      ol.list-decimal > li {
        text-indent: -1.1em;
        padding-left: 1.1em;
      }
      
      
    </style>

    <!-- Chart 01 -->
    <div id="chart-01" data-chart-index="1" class="scroll-mt-24">
      <div class="relative bg-gradient-to-br from-amber-200 to-yellow-200 border-2 border-amber-500 rounded-xl shadow-2xl p-6 mb-14 mt-8">
      <h2 id="chart-01-title" class="text-xl font-semibold mb-2 text-vintage-ink">1. Incidents of Anti-Chinese Violence Over Time</h2>
             <p id="tagline-chart-1" class="mb-4 text-sm text-vintage-ink">Annual count of anti-Chinese violence events, 1850–1920.</p>
      <div id="chart-timeline" 
           class="chart-container"
           role="img"
           aria-label="Line chart showing incidents of anti-Chinese violence from 1850 to 1920"
           aria-describedby="chart-timeline-desc"></div>
      <p id="chart-timeline-desc" class="sr-only">This chart displays annual counts of anti-Chinese violence incidents. Peak years include 1885 with 15 incidents and 1886 with 12 incidents. Use the data table below for detailed values.</p>
      <div id="chart-timeline-table" class="sr-only" role="region" aria-label="Data table for incidents over time chart"></div>
      <a href="#charts-top" class="absolute bottom-2 right-4 text-xs text-vintage-ink/60 hover:text-vintage-ink hover:underline" aria-label="Back to top">top</a>
      </div>
    </div>

    <!-- Chart 02 -->
    <div id="chart-02" data-chart-index="2" class="scroll-mt-24">
      <div class="relative bg-gradient-to-br from-amber-200 to-yellow-200 border-2 border-amber-500 rounded-xl shadow-2xl p-6 mb-14">
      <h2 class="text-xl font-semibold mb-2 text-vintage-ink">2. Number of Victims of Anti-Chinese Violence Over Time</h2>
             <p id="tagline-chart-2" class="mb-4 text-sm text-vintage-ink">Annual count of victims, 1850–1920.</p>
      <div id="chart-victims" 
           class="chart-container"
           role="img"
           aria-label="Line chart showing number of victims of anti-Chinese violence from 1850 to 1920"
           aria-describedby="chart-victims-desc"></div>
      <p id="chart-victims-desc" class="sr-only">This chart displays annual counts of victims of anti-Chinese violence. Use the data table below for detailed values.</p>
      <div id="chart-victims-table" class="sr-only" role="region" aria-label="Data table for victims over time chart"></div>
      <a href="#charts-top" class="absolute bottom-2 right-4 text-xs text-vintage-ink/60 hover:text-vintage-ink hover:underline" aria-label="Back to top">top</a>
      </div>
    </div>

    <!-- Chart 03 -->
    <div id="chart-03" data-chart-index="3" class="scroll-mt-24">
      <div class="relative bg-gradient-to-br from-amber-200 to-yellow-200 border-2 border-amber-500 rounded-xl shadow-2xl p-6 mb-14">
      <h2 id="chart-03-title" class="text-xl font-semibold mb-2 text-vintage-ink">3. Number Incidents and Victims Over Time</h2>
      <p id="tagline-chart-3-inc-vic" class="mb-4 text-sm text-vintage-ink">Incidents (N=75) and victims (N=191) from 1850–1920. Average number of victims per incident: 2.5.</p>
      <div id="chart-incidents-victims"
           class="chart-container"
           role="img"
           aria-label="Area chart showing incidents and victims of anti-Chinese violence from 1850 to 1920"
           aria-describedby="chart-incidents-victims-desc"></div>
      <p id="chart-incidents-victims-desc" class="sr-only">Stacked area chart of incidents (bottom) and victims (top) by year. Use the data table below for detailed values.</p>
      <div id="chart-incidents-victims-table" class="sr-only" role="region" aria-label="Data table for incidents and victims over time chart"></div>
      <a href="#charts-top" class="absolute bottom-2 right-4 text-xs text-vintage-ink/60 hover:text-vintage-ink hover:underline" aria-label="Back to top">top</a>
      </div>
    </div>

    <!-- Chart 04 -->
    <div id="chart-04" data-chart-index="4" class="scroll-mt-24">
      <div class="relative bg-gradient-to-br from-amber-200 to-yellow-200 border-2 border-amber-500 rounded-xl shadow-2xl p-6 mb-14">
      <h2 class="text-xl font-semibold mb-2 text-vintage-ink">4.a. Number of Lethal Events by State Over Time</h2>
      <p id="tagline-chart-4a" class="mb-4 text-sm text-vintage-ink">Stacked bar chart: incidents per decade, broken down by state.</p>
      <div id="chart-lethal-events-state"
           class="chart-container"
           role="img"
           aria-label="Stacked bar chart showing number of lethal events by decade and state"
           aria-describedby="chart-lethal-events-state-desc"></div>
      <p id="chart-lethal-events-state-desc" class="sr-only">Stacked bar chart of lethal events by decade, with segments for each state. Use the data table below for detailed values.</p>
      <div id="chart-lethal-events-state-table" class="sr-only" role="region" aria-label="Data table for lethal events by state chart"></div>
      <a href="#charts-top" class="absolute bottom-2 right-4 text-xs text-vintage-ink/60 hover:text-vintage-ink hover:underline" aria-label="Back to top">top</a>
      </div>
    </div>

    <!-- Chart 05 -->
    <div id="chart-05" data-chart-index="5" class="scroll-mt-24">
      <div class="relative bg-gradient-to-br from-amber-200 to-yellow-200 border-2 border-amber-500 rounded-xl shadow-2xl p-6 mb-14">
      <h2 class="text-xl font-semibold mb-2 text-vintage-ink">4.b. Number of Victims by State Over Time</h2>
      <p id="tagline-chart-4b" class="mb-4 text-sm text-vintage-ink">Stacked bar chart: victims per decade, broken down by state.</p>
      <div id="chart-victims-state"
           class="chart-container"
           role="img"
           aria-label="Stacked bar chart showing number of victims by decade and state"
           aria-describedby="chart-victims-state-desc"></div>
      <p id="chart-victims-state-desc" class="sr-only">Stacked bar chart of victims by decade, with segments for each state. Use the data table below for detailed values.</p>
      <div id="chart-victims-state-table" class="sr-only" role="region" aria-label="Data table for victims by state chart"></div>
      <a href="#charts-top" class="absolute bottom-2 right-4 text-xs text-vintage-ink/60 hover:text-vintage-ink hover:underline" aria-label="Back to top">top</a>
      </div>
    </div>

    <!-- Chart 06 -->
    <div id="chart-06" data-chart-index="6" class="scroll-mt-24">
      <div class="relative bg-gradient-to-br from-amber-200 to-yellow-200 border-2 border-amber-500 rounded-xl shadow-2xl p-6 mb-14">
      <h2 id="chart-06-title" class="text-xl font-semibold mb-2 text-vintage-ink">4.c. Incident and Victim Count by State</h2>
      <p id="tagline-chart-4c" class="mb-4 text-sm text-vintage-ink">Incidents (blue) and victims (red) per state, sorted by victim count.</p>
      <div id="chart-incident-victim-by-state"
           class="chart-container" style="height:450px;"
           role="img"
           aria-label="Horizontal bar chart showing incident and victim count by state"
           aria-describedby="chart-incident-victim-by-state-desc"></div>
      <p id="chart-incident-victim-by-state-desc" class="sr-only">Horizontal bar chart of incident count (blue) and victim count (red) by state, sorted by victim count. Use the data table below for detailed values.</p>
      <div id="chart-incident-victim-by-state-table" class="sr-only" role="region" aria-label="Data table for incident and victim count by state chart"></div>
      <a href="#charts-top" class="absolute bottom-2 right-4 text-xs text-vintage-ink/60 hover:text-vintage-ink hover:underline" aria-label="Back to top">top</a>
      </div>
    </div>

    <!-- Chart 07 -->
    <div id="chart-07" data-chart-index="7" class="scroll-mt-24">
      <div class="relative bg-gradient-to-br from-amber-200 to-yellow-200 border-2 border-amber-500 rounded-xl shadow-2xl p-6 mb-14">
      <h2 class="text-xl font-semibold mb-2 text-vintage-ink">5. Types of Anti-Chinese Violence</h2>
             <p id="tagline-chart-5" class="mb-4 text-sm text-vintage-ink">Breakdown of event types in the lynching records.</p>
      <div id="chart-types" 
           class="chart-container"
           role="img"
           aria-label="Bar chart showing types of anti-Chinese violence by victim count"
           aria-describedby="chart-types-desc"></div>
      <p id="chart-types-desc" class="sr-only">This chart displays a breakdown of event types in the lynching records, showing the number of victims for each type. Use the data table below for detailed values.</p>
      <div id="chart-types-table" class="sr-only" role="region" aria-label="Data table for types of violence chart"></div>
      <a href="#charts-top" class="absolute bottom-2 right-4 text-xs text-vintage-ink/60 hover:text-vintage-ink hover:underline" aria-label="Back to top">top</a>
      </div>
    </div>

    <!-- Chart 08/09 container -->
    <div class="relative bg-gradient-to-br from-amber-200 to-yellow-200 border-2 border-amber-500 rounded-xl shadow-2xl p-4 mb-14">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-2">
        <!-- Chart 08 -->
        <div id="chart-08" data-chart-index="8" class="relative scroll-mt-24">
          <h2 class="text-lg font-semibold mb-1 text-vintage-ink text-center">6.a. Categories of Violence</h2>
          <p id="tagline-chart-6a" class="text-center text-xs text-vintage-ink mb-1">Distribution of violence categories.</p>
          <div id="chart-pie-category" 
               style="width: 100%; height: 280px;"
               role="img"
               aria-label="Pie chart showing distribution of categories of violence"
               aria-describedby="chart-pie-category-desc"></div>
          <p id="chart-pie-category-desc" class="sr-only">This pie chart displays the distribution of categories of violence. Use the data table below for detailed values.</p>
          <div id="chart-pie-category-table" class="sr-only" role="region" aria-label="Data table for categories of violence chart"></div>
          <a href="#charts-top" class="absolute bottom-0 right-2 text-xs text-vintage-ink/60 hover:text-vintage-ink hover:underline" aria-label="Back to top">top</a>
        </div>
        <!-- Chart 09 -->
        <div id="chart-09" data-chart-index="9" class="relative scroll-mt-24">
          <h2 class="text-lg font-semibold mb-1 text-vintage-ink text-center">6.b. Pretexts for Violence</h2>
          <p id="tagline-chart-6b" class="text-center text-xs text-vintage-ink mb-1">Distribution of stated pretexts.</p>
          <div id="chart-pie-pretext" 
               style="width: 100%; height: 280px;"
               role="img"
               aria-label="Pie chart showing distribution of pretexts for violence"
               aria-describedby="chart-pie-pretext-desc"></div>
          <p id="chart-pie-pretext-desc" class="sr-only">This pie chart displays the distribution of pretexts for violence. Use the data table below for detailed values.</p>
          <div id="chart-pie-pretext-table" class="sr-only" role="region" aria-label="Data table for pretexts for violence chart"></div>
          <a href="#charts-top" class="absolute bottom-0 right-2 text-xs text-vintage-ink/60 hover:text-vintage-ink hover:underline" aria-label="Back to top">top</a>
        </div>
      </div>
    </div>

    <!-- Chart 10 -->
    <div id="chart-10" data-chart-index="10" class="relative bg-gradient-to-br from-amber-200 to-yellow-200 border-2 border-amber-500 rounded-xl shadow-2xl p-4 mb-14 scroll-mt-24">
      <h2 class="text-xl font-semibold mb-1 text-vintage-ink text-center">7. Killing Method</h2>
      <p id="tagline-chart-7" class="text-center text-xs text-vintage-ink mb-1">Distribution of killing methods.</p>
      <div id="chart-pie-killing-method"
           style="width: 100%; height: 280px;"
           role="img"
           aria-label="Pie chart showing distribution of killing method"
           aria-describedby="chart-pie-killing-method-desc"></div>
      <p id="chart-pie-killing-method-desc" class="sr-only">This pie chart displays the distribution of killing method. Use the data table below for detailed values.</p>
      <div id="chart-pie-killing-method-table" class="sr-only" role="region" aria-label="Data table for killing method chart"></div>
      <a href="#charts-top" class="absolute bottom-2 right-4 text-xs text-vintage-ink/60 hover:text-vintage-ink hover:underline" aria-label="Back to top">top</a>
    </div>

    <!-- Chart 11 -->
    <div id="chart-11" data-chart-index="11" class="scroll-mt-24">
      <div class="relative bg-gradient-to-br from-amber-200 to-yellow-200 border-2 border-amber-500 rounded-xl shadow-2xl p-6 mb-12">
      <h2 id="chart-11-title" class="text-xl font-semibold mb-2 text-vintage-ink">8. Anti-Chinese Violence & Chinese Population in the U.S. (1850–1915)</h2>
             <p class="mb-4 text-sm text-vintage-ink">A combination chart showing the number of victims per year (bar), the Chinese population (line), and key policy events (vertical markers).</p>
      <div id="chart-combo" 
           class="chart-container-large"
           role="img"
           aria-label="Combination chart showing victims per year, Chinese population, and key policy events from 1850 to 1915"
           aria-describedby="chart-combo-desc"></div>
      <p id="chart-combo-desc" class="sr-only">This combination chart displays the number of victims per year as bars, the Chinese population as a line, and key policy events as vertical markers. Use the data table below for detailed values.</p>
      <div id="chart-combo-table" class="sr-only" role="region" aria-label="Data table for combination chart"></div>
      <a href="#charts-top" class="absolute bottom-2 right-4 text-xs text-vintage-ink/60 hover:text-vintage-ink hover:underline" aria-label="Back to top">top</a>
      </div>
    </div>

    <!-- Chart 9: Hong Di articles by state (Mapbox choropleth) -->
    <div id="chart-12" data-chart-index="12" class="scroll-mt-24">
      <div class="relative bg-gradient-to-br from-amber-200 to-yellow-200 border-2 border-amber-500 rounded-xl shadow-2xl p-6 mb-14">
      <h2 id="chart-09-title" class="text-xl font-semibold mb-2 text-vintage-ink">9. Distribution of Hong Di Lynching Reports by State (N=1,406)</h2>
      <p id="tagline-chart-9" class="mb-4 text-sm text-vintage-ink">Newspaper articles reporting the Hong Di lynching (Colusa, California, July 1887), by state of publication.</p>
      <link rel="stylesheet" href="https://api.mapbox.com/mapbox-gl-js/v3.0.1/mapbox-gl.css" />
      <div class="relative">
      <button id="hong-di-map-reset" type="button" class="absolute top-3 left-3 z-10 px-3 py-1.5 text-sm font-medium bg-white/90 hover:bg-white border border-gray-300 rounded shadow-md text-vintage-ink" aria-label="Reset map view">Reset</button>
      <div id="chart-hong-di-by-state"
           class="chart-container rounded-lg overflow-hidden" style="height:500px;min-height:400px;"
           role="img"
           aria-label="Choropleth map showing number of Hong Di lynching articles per state"
           aria-describedby="chart-hong-di-by-state-desc"></div>
      </div>
      <p id="chart-hong-di-by-state-desc" class="sr-only">Choropleth map of newspaper article counts by state of publication for the Hong Di lynching. Use the data table below for detailed values.</p>
      <div id="chart-hong-di-by-state-table" class="sr-only" role="region" aria-label="Data table for Hong Di articles by state chart"></div>
      <a href="#charts-top" class="absolute bottom-2 right-4 text-xs text-vintage-ink/60 hover:text-vintage-ink hover:underline" aria-label="Back to top">top</a>
      </div>
    </div>

    <!-- Chart 10: Chinese Must Go mentions by state (Mapbox choropleth) -->
    <div id="chart-13" data-chart-index="13" class="scroll-mt-24">
      <div class="relative bg-gradient-to-br from-amber-200 to-yellow-200 border-2 border-amber-500 rounded-xl shadow-2xl p-6 mb-14">
      <h2 id="chart-13-title" class="text-xl font-semibold mb-2 text-vintage-ink">10. Distribution of "Chinese Must Go" Mentions by State (N=2,875)</h2>
      <p id="tagline-chart-10" class="mb-4 text-sm text-vintage-ink">Newspaper mentions of the anti-Chinese slogan "Chinese must go" by state of publication, 1878–1925.</p>
      <div class="relative">
      <button id="chinese-must-go-map-reset" type="button" class="absolute top-3 left-3 z-10 px-3 py-1.5 text-sm font-medium bg-white/90 hover:bg-white border border-gray-300 rounded shadow-md text-vintage-ink" aria-label="Reset map view">Reset</button>
      <div id="chart-chinese-must-go-by-state"
           class="chart-container rounded-lg overflow-hidden" style="height:500px;min-height:400px;"
           role="img"
           aria-label="Choropleth map showing Chinese Must Go mentions per state"
           aria-describedby="chart-chinese-must-go-by-state-desc"></div>
      </div>
      <p id="chart-chinese-must-go-by-state-desc" class="sr-only">Choropleth map of newspaper mentions of the Chinese must go slogan by state of publication. Use the data table below for detailed values.</p>
      <div id="chart-chinese-must-go-by-state-table" class="sr-only" role="region" aria-label="Data table for Chinese Must Go mentions by state chart"></div>
      <a href="#charts-top" class="absolute bottom-2 right-4 text-xs text-vintage-ink/60 hover:text-vintage-ink hover:underline" aria-label="Back to top">top</a>
      </div>
    </div>
  </div>
  <script is:inline src="https://api.mapbox.com/mapbox-gl-js/v3.0.1/mapbox-gl.js"></script>
  <script is:inline src="https://cdn.jsdelivr.net/npm/@turf/turf@6/turf.min.js"></script>
  <script is:inline src="https://cdn.jsdelivr.net/npm/echarts@5.4.3/dist/echarts.min.js"></script>
  <script is:inline define:vars={{ mapboxToken, mapboxStyle, hongDiByState: HONG_DI_BY_STATE, chineseMustGoByState: CHINESE_MUST_GO_BY_STATE }}>
    (function() {
    function initAllCharts() {
      if (typeof echarts === 'undefined') {
        setTimeout(initAllCharts, 100);
        return;
      }
      var nocache = new URLSearchParams(window.location.search).get('nocache') === '1';
      var apiSuffix = nocache ? '&nocache=1' : '';
      Promise.all([
        fetch('/timeline.json').then(function(r) { return r.json(); }).catch(function() { return []; }),
        fetch('/api/lynchings' + (nocache ? '?nocache=1' : '')).then(function(r) { return r.json(); }).catch(function() { return []; }),
        fetch('/api/lynchings?gid=760826284' + apiSuffix).then(function(r) { return r.json(); }).catch(function() { return []; }),
      ]).then(function(results) {
        var timelineData = results[0];
        var lynchingsData = Array.isArray(results[1]) ? results[1] : [];
        var mainTabData = Array.isArray(results[2]) ? results[2] : lynchingsData;
        renderCharts(timelineData, lynchingsData, mainTabData, hongDiByState, chineseMustGoByState);
      });
    }
    function renderCharts(timelineData, lynchingsData, mainTabData, hongDiByState, chineseMustGoByState) {
      hongDiByState = hongDiByState || {};
      chineseMustGoByState = chineseMustGoByState || {};

    // --- Chart 1: Incidents Over Time ---
    // Use Main tab (Chinese lynchings master): incidents = row count per year, victims = sum per year
