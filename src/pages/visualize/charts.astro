            });
            chineseMustGoMap.addSource('state-labels', { type: 'geojson', data: labelsGeoJSON });
            chineseMustGoMap.addLayer({
              id: 'state-labels',
              type: 'symbol',
              source: 'state-labels',
              layout: {
                'text-field': ['get', 'label'],
                'text-size': 13,
                'text-font': ['Open Sans Bold', 'Arial Unicode MS Bold'],
                'text-anchor': 'center',
                'text-justify': 'center',
                'text-max-width': 10,
                'text-allow-overlap': true,
                'text-ignore-placement': true
              },
              paint: {
                'text-color': '#0f172a',
                'text-halo-color': '#ffffff',
                'text-halo-width': 1
              }
            });
            var popup = new mapboxgl.Popup({ closeButton: false, closeOnClick: false });
            chineseMustGoMap.on('mousemove', 'state-fills', function(e) {
              if (e.features.length) {
                chineseMustGoMap.getCanvas().style.cursor = 'pointer';
                var f = e.features[0];
                var name = f.properties.STATE_NAME;
                var n = f.properties.mentions || 0;
                popup.setLngLat(e.lngLat).setHTML('<strong>' + name + '</strong>: ' + n + ' mention' + (n !== 1 ? 's' : '')).addTo(chineseMustGoMap);
              }
            });
            chineseMustGoMap.on('mouseleave', 'state-fills', function() {
              chineseMustGoMap.getCanvas().style.cursor = '';
              popup.remove();
            });
            var resetBtn = document.getElementById('chinese-must-go-map-reset');
            if (resetBtn) {
              resetBtn.onclick = function() {
                chineseMustGoMap.flyTo({ center: [-96, 38], zoom: 3.5, duration: 500 });
              };
            }
          });
        })
        .catch(function() {
          if (container) container.innerHTML = '<div class="flex items-center justify-center h-full text-vintage-ink bg-amber-50 rounded-lg"><p class="text-center px-4">Could not load map data.</p></div>';
        });
    }
    initChineseMustGoMap();

    function renderPolicyEventGraphics() {
      var graphics = policyEvents.map(function(event) {
        var useAltRow = event.year === 1882 || event.year === 1892;
        var labelValue = useAltRow ? labelTopAlt : labelTop;
        var labelPixel = chartCombo.convertToPixel({ xAxisIndex: 0, yAxisIndex: 0 }, [String(event.year), labelValue]);
        var axisPixel = chartCombo.convertToPixel({ xAxisIndex: 0, yAxisIndex: 0 }, [String(event.year), 0]);
        if (!labelPixel || !axisPixel) return null;
        return {
          type: 'group',
          silent: true,
          z: 10,
          zlevel: 2,
          children: [
            {
              type: 'line',
              shape: {
                x1: labelPixel[0],
                y1: labelPixel[1] + 4,
                x2: labelPixel[0],
                y2: axisPixel[1]
              },
              style: {
                stroke: '#7A6B5A',
                lineWidth: 1,
                lineDash: [4, 4]
              }
            },
            {
              type: 'text',
              style: {
                text: event.label,
                x: labelPixel[0],
                y: labelPixel[1] - 4,
                font: 'bold 11px sans-serif',
                fill: '#333',
                textAlign: 'center',
                textVerticalAlign: 'bottom'
              }
            }
          ]
        };
      }).filter(Boolean);
      chartCombo.setOption({ graphic: graphics });
    }

    chartCombo.on('finished', renderPolicyEventGraphics);
    renderPolicyEventGraphics();

    // Update taglines with grand totals (N=...)
    const totalIncidents = counts.reduce((a, b) => a + b, 0);
    const totalVictims = victimCounts.reduce((a, b) => a + b, 0);
    const totalTypesVictims = typeVals.reduce((a, b) => a + b, 0);
    const totalCategory = categoryData.reduce((s, d) => s + d.value, 0);
    const totalPretext = pretextData.reduce((s, d) => s + d.value, 0);
    const totalKillingMethod = killingMethodData.reduce((s, d) => s + d.value, 0);
    const el = (id, base, n) => { const e = document.getElementById(id); if (e) e.textContent = base + ` (N=${n})`; };
    el('tagline-chart-1', 'Annual count of anti-Chinese violence events, 1850–1920.', totalIncidents);
    el('tagline-chart-2', 'Annual count of victims, 1850–1920.', totalVictims);
    { const avg = totalIncidents ? (totalVictims / totalIncidents).toFixed(1) : '0'; const e = document.getElementById('tagline-chart-3-inc-vic'); if (e) e.textContent = `Incidents (N=${totalIncidents}) and victims (N=${totalVictims}) from 1850–1920. Average number of victims per incident: ${avg}.`; }
    el('tagline-chart-4a', 'Stacked bar chart: incidents per decade, broken down by state.', totalIncidents);
    el('tagline-chart-4b', 'Stacked bar chart: victims per decade, broken down by state.', totalVictims);
    { const e = document.getElementById('tagline-chart-4c'); if (e) e.textContent = `Incidents (blue) and victims (red) per state, sorted by victim count (N=${totalIncidents} incidents, N=${totalVictims} victims).`; }
    el('tagline-chart-5', 'Breakdown of event types in the lynching records.', totalTypesVictims);
    el('tagline-chart-6a', 'Distribution of violence categories.', totalCategory);
    el('tagline-chart-6b', 'Distribution of stated pretexts.', totalPretext);
    el('tagline-chart-7', 'Distribution of killing methods.', totalKillingMethod);

    const resizeAllCharts = () => {
      chartTimeline.resize();
      chartVictims.resize();
      chartIncidentsVictims.resize();
      chartLethal.resize();
      chartVictimsState.resize();
      chartIncidentVictimState.resize();
      chartTypes.resize();
      chartPieCategory.resize();
      chartPiePretext.resize();
      chartPieKillingMethod.resize();
      chartCombo.resize();
      if (hongDiMap) hongDiMap.resize();
      if (chineseMustGoMap) chineseMustGoMap.resize();
      setTimeout(renderPolicyEventGraphics, 60);
    };

    window.addEventListener('resize', resizeAllCharts);
    requestAnimationFrame(function() { setTimeout(resizeAllCharts, 50); });
    } // end renderCharts
    initAllCharts();
    })();
  </script>
</PageLayout>