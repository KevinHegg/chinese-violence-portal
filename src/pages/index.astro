---
// Landing page with navbar and cards
import "../styles/tailwind.css";
import Navbar from "../components/Navbar.astro";
import NavCard from "../components/NavCard.astro";
import { fetchLynchingsData, fetchLynchingsMainData } from "../utils/googleSheets";
import { getMapboxStaticImageUrl } from "../utils/mapboxStaticImage";

// Disable prerendering to allow dynamic data from Google Sheets
export const prerender = false;

// Fetch lynchings data for count (Public tab) and featured record (Main tab)
const mainTabGid = import.meta.env.PUBLIC_LYNCHINGS_MAIN_GID || "760826284";
const [publicResult, mainResult] = await Promise.allSettled([
  fetchLynchingsData(),
  fetchLynchingsMainData(mainTabGid)
]);

const lynchingsData = publicResult.status === "fulfilled" ? publicResult.value : [];
const lynchingsMainData = mainResult.status === "fulfilled" ? mainResult.value : [];
const incidentCount = lynchingsData.length;
// Calculate total victim count from "number-of-victims" column
const victimCount = lynchingsData.reduce((sum, record) => {
  const victims = parseInt(record["number-of-victims"]) || 0;
  return sum + victims;
}, 0);

// Select a random featured record on each request (prefer Main tab for Narrative Summary)
const featuredSource = lynchingsMainData.length > 0 ? lynchingsMainData : lynchingsData;
const featuredRecord = featuredSource.length > 0
  ? featuredSource[Math.floor(Math.random() * featuredSource.length)]
  : null;
---

<!doctype html>
<html lang="en" data-theme="johncrow">
  <head>
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-EHFB9XXVEP"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-EHFB9XXVEP');
    </script>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>The John Crow Project</title>
    <meta name="description" content="Documenting the history of anti-Chinese lynching, exclusion, and resistance in the American West (1850–1915). Explore interactive records, maps, timelines, and primary-source newspaper articles to uncover this neglected chapter of American history." />
    <meta name="keywords" content="John Crow, anti-Chinese violence, Chinese lynching, American West, Chinese Exclusion, anti-Asian racism, digital history, primary sources, 1850-1915" />
    
    <!-- Enhanced Structured Data for Homepage -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "CollectionPage",
      "name": "The John Crow Project",
      "description": "Comprehensive digital archive documenting anti-Chinese violence in the American West (1850-1915), including {incidentCount} documented incidents, {victimCount} victims, and 140+ primary source newspaper articles.",
      "url": "https://johncrow.org",
      "mainEntity": {
        "@type": "DataCatalog",
        "name": "Anti-Chinese Violence Database",
        "description": "Searchable database of lynchings, riots, and massacres targeting Chinese immigrants in the American West",
        "temporalCoverage": "1850/1915",
        "spatialCoverage": {
          "@type": "Place",
          "name": "American West"
        },
        "numberOfItems": {incidentCount},
        "license": "https://creativecommons.org/licenses/by-nc/4.0/"
      },
      "hasPart": [
        {
          "@type": "WebPage",
          "name": "Explore Records",
          "url": "https://johncrow.org/explore",
          "description": "Search and filter {incidentCount} documented incidents of anti-Chinese violence"
        },
        {
          "@type": "WebPage",
          "name": "Data Visualizations",
          "url": "https://johncrow.org/visualize",
          "description": "Interactive charts, maps, and timelines showing patterns of violence over time"
        },
        {
          "@type": "WebPage",
          "name": "Primary Sources",
          "url": "https://johncrow.org/news",
          "description": "140+ digitized newspaper articles with full transcripts"
        }
      ],
      "creator": {
        "@type": "Person",
        "name": "Kevin Hegg",
        "jobTitle": "Historian"
      },
      "datePublished": "2025-01-24",
      "inLanguage": "en-US"
    }
    </script>
  </head>
  <body class="font-serif" data-current-page="home">
    <Navbar currentPage="home" />
    
    <main class="p-6 pt-8">
      <div class="container-standard">
        <div class="text-center mb-8">
          <h1 class="text-3xl font-display font-bold mb-4 text-base-content">
            The John Crow Project
          </h1>
          
          <p class="text-lg font-body text-base-content/80 max-w-3xl mx-auto leading-relaxed">
            Documenting the history of anti-Chinese lynchings, riots, and massacres<br>in the American West (1850 – 1915)
          </p>
        </div>

        <div id="tour-root"></div>

        <section id="home-framing" aria-labelledby="what-is-site-title" class="card-vintage p-6 mb-8">
          <h2 id="what-is-site-title" class="text-2xl font-display font-semibold mb-3 text-base-content">What Is the John Crow Project?</h2>
          <p class="font-body text-base-content/90 leading-relaxed mb-3">
            Between the California Gold Rush and the First World War, Chinese immigrants were subjected to a coordinated regime of racial terror—lynchings, riots, expulsions, and legal exclusion. This project calls that Western system “John Crow”: a structure aimed at expulsion rather than subordination.
          </p>
          <p class="font-body text-base-content/90 leading-relaxed mb-3">
            Drawing on a newly compiled dataset of documented lynchings, digitized newspaper archives, and spatial analysis, this site reconstructs how violence spread—across towns, along rivers and railroads, and through national print networks.
          </p>
          <p class="font-body text-base-content/90 leading-relaxed mb-3">
            The interactive maps, timelines, and charts presented here translate the quantitative and spatial arguments of the dissertation into web-based form. Where possible, visualizations correspond directly to analytical figures developed in A Murder of Crows.
          </p>
          <p class="font-body text-base-content/90 leading-relaxed">
            <a href="/about/project-and-thesis" class="text-accent hover:text-accent-focus underline">
              Read the full thesis framing in About → Project &amp; Thesis.
            </a>
          </p>
        </section>

        <section aria-labelledby="quick-start-title" class="mb-8">
          <h2 id="quick-start-title" class="text-2xl font-display font-semibold mb-4 text-base-content">Quick Start</h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-4 mb-8">
            <NavCard id="qs-records" href="/explore" title="Explore Records" description="Browse lynching records by date, place, and event details.">
              <svg class="w-4 h-4 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5h10M11 9h7M11 13h4M7 5v14m0 0H5a2 2 0 01-2-2V7a2 2 0 012-2h2a2 2 0 012 2v12z" />
                <circle cx="17" cy="17" r="3" stroke="currentColor" stroke-width="2" fill="none" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-2-2" />
              </svg>
            </NavCard>
            <NavCard id="qs-news" href="/news" title="News Clips" description="Read article images, transcriptions, and source citations.">
              <svg class="w-4 h-4 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"></path>
              </svg>
            </NavCard>
            <NavCard id="qs-visualize" href="/visualize" title="Visualize" description="Open charts, maps, timelines, and comparative views.">
              <svg class="w-4 h-4 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path>
              </svg>
            </NavCard>
            <NavCard id="qs-dataset" href="/dataset" title="Dataset" description="Access structured data used across the archive.">
              <svg class="w-4 h-4 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                <rect x="3" y="5" width="18" height="14" rx="2" stroke="currentColor" stroke-width="2" fill="none" />
                <path stroke="currentColor" stroke-width="2" d="M3 9h18M3 13h18M7 5v14M17 5v14" />
              </svg>
            </NavCard>
            <NavCard id="qs-ask" href="/chat" title="Ask the Archive" description="Ask questions and trace evidence across records.">
              <svg class="w-4 h-4 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path>
              </svg>
            </NavCard>
          </div>
          <p class="text-sm font-body text-base-content/70">
            New to the site? <a href="/tour" class="text-accent hover:text-accent-focus underline">Take the guided tour.</a>
          </p>
        </section>

        <!-- Featured Record Section -->
        {featuredRecord && (
          <section aria-labelledby="featured-record-title" class="mb-8">
            <h2 id="featured-record-title" class="text-2xl font-display font-semibold mb-4 text-base-content">Featured Record</h2>
            <a href={`/records/${featuredRecord["lynching-id"]}`} class="block bg-white border border-amber-200 rounded-lg p-5 shadow-md hover:shadow-lg transition-shadow">
              <div class="flex flex-col md:flex-row gap-4">
                <div class="flex-shrink-0">
                  {(() => {
                    const hasCoordinates = !!(featuredRecord.latitude && featuredRecord.longitude &&
                                           featuredRecord.latitude !== 0 && featuredRecord.longitude !== 0);
                    const mapboxUrl = hasCoordinates
                      ? getMapboxStaticImageUrl(featuredRecord.longitude, featuredRecord.latitude, { width: 192, height: 128 })
                      : null;
                    const imageSrc = mapboxUrl || `/mapimages/${featuredRecord["lynching-id"]}.png`;
                    return (
                      <img
                        src={imageSrc}
                        alt={`Map showing location of ${featuredRecord["city"] || featuredRecord["county"]}, ${featuredRecord["state"]}`}
                        class="w-full md:w-48 h-32 object-cover rounded-lg border border-gray-200"
                        onerror="this.style.display='none'"
                      />
                    );
                  })()}
                </div>
                <div class="flex-1">
                  <div class="flex justify-between items-start mb-2">
                    <h3 class="text-lg font-display font-semibold text-gray-900">{featuredRecord["narrative-short-title"]}</h3>
                    <span class="text-sm text-gray-500 ml-2 flex-shrink-0">{featuredRecord["date"]}</span>
                  </div>
                  <p class="text-sm text-gray-600 mb-2">
                    {featuredRecord["city"] ? `${featuredRecord["city"]}, ` : ''}{featuredRecord["state"]} • {featuredRecord["event-type"]}
                  </p>
                  <p class="text-sm text-gray-700 line-clamp-3">
                    {featuredRecord["narrative-body"] || featuredRecord["narrative-summary"]}
                  </p>
                  <span class="inline-block mt-3 text-sm font-medium text-accent hover:text-accent-focus">Read full record →</span>
                </div>
              </div>
            </a>
          </section>
        )}

        <footer class="text-center mt-12 pt-8 border-t border-base-300">
          <div class="mb-3">
            <a href="/accessibility" class="inline-flex items-center gap-2 px-4 py-2 text-sm font-medium text-vintage-ink bg-amber-50 hover:bg-amber-100 border border-amber-300 rounded-lg transition-colors duration-200">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
              </svg>
              WCAG 2.2 AA Compliant
            </a>
          </div>
          <p class="text-sm font-body text-base-content/70">
            © Kevin Hegg, 2025. This website contains sensitive historical content. Please approach the material with respect and care.
          </p>
        </footer>
      </div>
    </main>
    <script>
      import { shouldAutoStartQuickTour, startQuickTour, clearQuickTourStartFlag } from "../lib/tour/quickTour";

      const bootQuickTour = () => {
        const tourRequested = shouldAutoStartQuickTour();
        if (!tourRequested) return;

        const isSmallScreen = window.innerWidth < 768;
        if (isSmallScreen) {
          clearQuickTourStartFlag();
          const mount = document.getElementById("tour-root");
          if (mount && !document.getElementById("tour-mobile-notice")) {
            const notice = document.createElement("div");
            notice.id = "tour-mobile-notice";
            notice.className = "mb-4 border border-amber-200 bg-amber-50 text-gray-800 rounded-lg px-4 py-3 shadow-sm flex items-start gap-3";
            notice.setAttribute("role", "status");
            notice.innerHTML = `
              <p class="text-sm leading-relaxed flex-1">Tour works best on a larger screen. You can still explore using the Quick Start buttons below.</p>
              <button type="button" class="text-sm font-semibold text-accent hover:text-accent-focus underline" aria-label="Dismiss tour notice">Dismiss</button>
            `;
            const dismiss = notice.querySelector("button");
            dismiss?.addEventListener("click", () => notice.remove());
            mount.appendChild(notice);
          }
          const url = new URL(window.location.href);
          if (url.searchParams.get("tour") === "1") {
            url.searchParams.delete("tour");
            window.history.replaceState({}, "", `${url.pathname}${url.search}${url.hash}`);
          }
          return;
        }

        startQuickTour();
      };

      if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", bootQuickTour, { once: true });
      } else {
        bootQuickTour();
      }
    </script>
  </body>
</html>

<style>
  html,
  body {
    margin: 0;
    width: 100%;
    height: 100%;
  }
</style>
